# =============================================================================
# Sovereign AI Hub — Environment Configuration
# Copy to .env and fill in values
# =============================================================================

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sovereign_ai
POSTGRES_USER=sovereign
POSTGRES_PASSWORD=changeme_in_production

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- vLLM ---
VLLM_HOST=vllm
VLLM_PORT=8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=8192
VLLM_ENABLE_TOOL_CHOICE=true

# --- llama.cpp (fallback) ---
LLAMA_CPP_HOST=llama-cpp
LLAMA_CPP_PORT=8080
LLAMA_CPP_MODEL_PATH=/models/llm/default.gguf
LLAMA_CPP_CONTEXT_SIZE=8192
LLAMA_CPP_GPU_LAYERS=99

# --- Embedding Model ---
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# --- Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8888
GATEWAY_SECRET_KEY=changeme_generate_a_real_key
GATEWAY_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8888
NEXT_PUBLIC_APP_NAME=Sovereign AI Hub

# --- Auth ---
AUTH_MODE=local
# AUTH_MODE=keycloak
# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=sovereign-ai
# KEYCLOAK_CLIENT_ID=sovereign-ai-hub

# --- Agent Runtime ---
AGENT_RUNTIME_HOST=agent-runtime
AGENT_RUNTIME_GRPC_PORT=50051
AGENT_SANDBOX_IMAGE=sovereign-ai-sandbox:latest
AGENT_MAX_ITERATIONS=20
AGENT_MAX_EXECUTION_TIME=300

# --- Air-Gap Mode ---
AIRGAP_MODE=false
# When true: all external network calls are blocked

# --- Model Store ---
MODEL_STORE_PATH=/models
